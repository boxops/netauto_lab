      },
      "title": "Interface Traffic - $device",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(ifHCInOctets{instance=\"$device\"}[5m]) * 8",
          "legendFormat": "{{ ifDescr }} in"
        },
        {
          "expr": "rate(ifHCOutOctets{instance=\"$device\"}[5m]) * 8 * -1",
          "legendFormat": "{{ ifDescr }} out"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
