# ============================================================
# INTERMEDIATE NETWORK AUTOMATION STACK - Environment Template
# Copy to .env and fill in values before running setup.sh
# NEVER commit .env with real credentials!
# ============================================================

# ---- General -----------------------------------------------
COMPOSE_PROJECT_NAME=netauto
TZ=UTC

# ---- Nautobot ----------------------------------------------
NAUTOBOT_SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM_KEY_50CHARS
NAUTOBOT_SUPERUSER_NAME=admin
NAUTOBOT_SUPERUSER_EMAIL=admin@example.com
NAUTOBOT_SUPERUSER_PASSWORD=CHANGE_ME_nautobot_admin_password
NAUTOBOT_SUPERUSER_API_TOKEN=CHANGE_ME_nautobot_api_token_40chars
NAUTOBOT_ALLOWED_HOSTS=*
NAUTOBOT_DB_NAME=nautobot
NAUTOBOT_DB_USER=nautobot
NAUTOBOT_DB_PASSWORD=CHANGE_ME_nautobot_db_password
NAUTOBOT_REDIS_PASSWORD=CHANGE_ME_redis_password
NAUTOBOT_LOG_LEVEL=INFO

# ---- PostgreSQL --------------------------------------------
POSTGRES_DB=nautobot
POSTGRES_USER=nautobot
POSTGRES_PASSWORD=CHANGE_ME_nautobot_db_password

# ---- Redis -------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_redis_password

# ---- Grafana -----------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password
GF_SERVER_ROOT_URL=http://localhost:3000

# ---- Prometheus --------------------------------------------
PROMETHEUS_RETENTION_TIME=30d

# ---- Loki --------------------------------------------------
LOKI_RETENTION_PERIOD=744h   # 31 days default; extend for 90d: 2160h

# ---- Gitea -------------------------------------------------
GITEA_ADMIN_USER=gitadmin
GITEA_ADMIN_PASSWORD=CHANGE_ME_gitea_admin_password
GITEA_ADMIN_EMAIL=gitadmin@example.com
GITEA_SECRET_KEY=CHANGE_ME_gitea_secret_key
GITEA_DB_NAME=gitea
GITEA_DB_USER=gitea
GITEA_DB_PASSWORD=CHANGE_ME_gitea_db_password

# ---- AI Agents ---------------------------------------------
# Provide your OpenAI API key or leave blank to use local Ollama
OPENAI_API_KEY=
# Local Ollama URL (used when OPENAI_API_KEY is empty)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
# LangSmith observability (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=netauto-agents

# ---- Ansible -----------------------------------------------
ANSIBLE_VAULT_PASSWORD=CHANGE_ME_ansible_vault_password

# ---- SNMP --------------------------------------------------
SNMP_COMMUNITY=public
SNMPV3_USER=netauto
SNMPV3_AUTH_PASS=CHANGE_ME_snmpv3_auth
SNMPV3_PRIV_PASS=CHANGE_ME_snmpv3_priv

# ---- Alertmanager ------------------------------------------
ALERTMANAGER_SLACK_WEBHOOK=https://hooks.slack.com/services/CHANGE_ME
ALERTMANAGER_SLACK_CHANNEL=#network-alerts
ALERTMANAGER_EMAIL_FROM=alerts@example.com
ALERTMANAGER_EMAIL_TO=oncall@example.com
ALERTMANAGER_SMTP_HOST=smtp.example.com:587
ALERTMANAGER_SMTP_USER=
ALERTMANAGER_SMTP_PASSWORD=

# ---- Host ports (change if there are conflicts) ------------
NAUTOBOT_PORT=8080
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GITEA_PORT=3001
GITEA_SSH_PORT=2222
AGENT_UI_PORT=7860
LOKI_PORT=3100
SYSLOG_UDP_PORT=514
SYSLOG_TCP_PORT=1514
