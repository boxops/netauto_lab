! Arista EOS – Intended Configuration
! Generated by Nautobot for {{ obj.name }}
!
no aaa root
!
username admin privilege 15 role network-admin secret admin
username netauto privilege 15 secret netauto
!
service routing protocols model ribd
!
{% if cc.logging.buffered -%}
logging buffered {{ cc.logging.buffered.size }} {{ cc.logging.buffered.level }}
{% endif -%}
{% for host in cc.logging.hosts %}logging host {{ host }}
{% endfor -%}
!
hostname {{ obj.name }}
!
{% if cc.snmp -%}
snmp-server community {{ cc.snmp.community }} ro
snmp-server host {{ cc.snmp.trap_host }} version 2c {{ cc.snmp.community }}
!
{% endif -%}
spanning-tree mode mstp
!
{% for vlan in device_vlans -%}
vlan {{ vlan.vid }}
   name {{ vlan.name }}
!
{% endfor -%}
management api http-commands
   no protocol https
   protocol http
   no shutdown
!
{% for iface in obj.interfaces.all() | sort(attribute='name') -%}
interface {{ iface.name }}
{% if iface.description %}   description '{{ iface.description }}'
{% endif -%}
{%- set ips = iface.ip_addresses.all() -%}
{% if ips %}
{%- if iface.name.startswith('Ethernet') or iface.name.startswith('Port-Channel') %}   no switchport
{% endif -%}
{%- for ip in ips %}   ip address {{ ip.address }}
{% endfor -%}
{%- elif iface.mode == 'access' and iface.untagged_vlan %}   switchport access vlan {{ iface.untagged_vlan.vid }}
{% endif -%}
!
{% endfor -%}
ip routing
!
{% for server in cc.ntp.servers %}ntp server {{ server }}
{% endfor -%}
!
{% if bgp_asn -%}
router bgp {{ bgp_asn }}
   router-id {{ bgp_router_id }}
   maximum-paths {{ bgp_max_paths }}
{% for n in bgp_neighbors %}   neighbor {{ n.ip }} remote-as {{ n.remote_as }}
   neighbor {{ n.ip }} send-community
   neighbor {{ n.ip }} maximum-routes 12000
{% endfor %}   !
   address-family ipv4
{% for n in bgp_neighbors %}      neighbor {{ n.ip }} activate
{% endfor %}{% for net in bgp_networks %}      network {{ net }}
{% endfor %}!
{% endif -%}
end
